@"
# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Env
.env
.env.*
*.key
env.py

# Python
staticfiles/
media/
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# Node / React
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Data (keep raw data out of git unless intentional)
data/raw/
data/interim/
*.sqlite3

# Secrets
*.pem
*.p12
"@ | Out-File -Encoding utf8 .gitignore

